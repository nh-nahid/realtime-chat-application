<%- include('./partials/header.ejs'); %>

    <link rel="stylesheet" href="/css/index.css">
    
</head>
<body>

<nav>
    <div class="logo">
        <div class="logo-icon">💬</div>
        <h2>ChatFlow</h2>
    </div>

    <div class="nav-links">
        <a href="/inbox">Inbox</a>
        <a href="/users">Users</a>
        <a href="/login">Login</a>
    </div>
</nav>

<div class="wrapper">

    <div class="login-container">

        <div class="hero">
            <h1>
                Connect,
                Chat &
                <span>Collaborate</span>
            </h1>

            <p>
                A modern real-time messaging platform designed for teams,
                communities and friends. Secure conversations with a sleek
                dark-green experience.
            </p>

            <div class="stats">
                <div class="stat-card">
                    <h3>10K+</h3>
                    <p>Users</p>
                </div>

                <div class="stat-card">
                    <h3>50K+</h3>
                    <p>Messages</p>
                </div>

                <div class="stat-card">
                    <h3>99.9%</h3>
                    <p>Uptime</p>
                </div>
            </div>
        </div>

        <div class="login-card">

            <h2>Welcome Back 👋</h2>
            <p>Login to continue chatting with your friends.</p>

            <form action="/login" method="POST">

                <div class="form-group">
                    <label>Email Address</label>
                    <input
                        type="email"
                        name="email"
                        placeholder="john@example.com"
                        required
                    >
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input
                        type="password"
                        name="password"
                        placeholder="••••••••"
                        required
                    >
                </div>

                <button class="login-btn" type="submit">
                    Login to Chat
                </button>

            </form>

            <div class="footer-text">
                Secure • Fast • Real-Time Messaging
            </div>

        </div>

    </div>

</div>

</body>
</html>