<%- include('./partials/header.ejs'); %>

<link rel="stylesheet" href="/css/index.css">

</head>
<body>

<%- include('./partials/nav.ejs', {
    active: 'login',
    loggedIn: false
}) %>

<div class="wrapper">

    <div class="login-container">

        <div class="hero">
            <h1>
                Connect,
                Chat &
                <span>Collaborate</span>
            </h1>

            <p>
                A modern real-time messaging platform designed for teams,
                communities and friends. Secure conversations with a sleek
                dark-green experience.
            </p>

            <div class="stats">
                <div class="stat-card">
                    <h3>10K+</h3>
                    <p>Users</p>
                </div>

                <div class="stat-card">
                    <h3>50K+</h3>
                    <p>Messages</p>
                </div>

                <div class="stat-card">
                    <h3>99.9%</h3>
                    <p>Uptime</p>
                </div>
            </div>
        </div>

        <div class="login-card">

            <h2>Welcome Back 👋</h2>
            <p>Login to continue chatting with your friends.</p>

            <form action="/" method="POST">

                <!-- USERNAME -->
                <div class="form-group">
                    <label>Email Address</label>
                    <input
                        type="text"
                        name="username"
                        placeholder="john@example.com"
                        value="<%= data?.username || '' %>"
                    >

                    <% if (errors && errors.username) { %>
                        <p class="error show">
                            <%= errors.username.msg %>
                        </p>
                    <% } %>
                </div>

                <!-- PASSWORD -->
                <div class="form-group">
                    <label>Password</label>
                    <input
                        type="password"
                        name="password"
                        placeholder="••••••••"
                        required
                    >

                    <% if (errors && errors.password) { %>
                        <p class="error show">
                            <%= errors.password.msg %>
                        </p>
                    <% } %>
                </div>

                <!-- COMMON ERROR -->
                <% if (errors && errors.common) { %>
                    <p class="error show">
                        <%= errors.common.msg %>
                    </p>
                <% } %>

                <button class="login-btn" type="submit">
                    Login to Chat
                </button>

            </form>

            <div class="footer-text">
                Secure • Fast • Real-Time Messaging
            </div>

        </div>

    </div>

</div>

</body>
</html>
<%- include('./partials/footer.ejs') %>