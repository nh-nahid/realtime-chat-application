<%- include('./partials/header.ejs'); %>

<link rel="stylesheet" href="/css/users.css">
<link rel="stylesheet" href="/css/toastify.css">

</head>
<body>

<%- include('./partials/nav.ejs', {
    active: 'users',
    loggedIn: true
}) %>

<div class="container">

    <div class="page-header">
        <h1>Manage Users</h1>

        <button
    class="add-btn"
    onclick="openModal()"
>
    +
</button>
    </div>

    <div class="table-wrapper">

        <table>

            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Message</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
    <% users.forEach(function(user) { %>
        <tr id="<%= user._id %>">

            <td class="name">
                <div class="user-cell">

                    <% if (user.avatar) { %>
                        <img 
                            src="/uploads/avatars/<%= user.avatar %>" 
                            class="avatar"
                        />
                    <% } else { %>
                        <div class="avatar">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>

                    <span><%= user.name %></span>
                </div>
            </td>

            <td class="email">
                <%= user.email %>
            </td>

            <td>
                <button class="message-btn">
                    Open Chat
                </button>
            </td>

            <td>
                <button class="delete-btn" onclick="deleteUser('<%= user._id %>')">
                    🗑
                </button>
            </td>

        </tr>
    <% }) %>
</tbody>

        </table>

    </div>

</div>
<!-- Create User Modal -->
<%- include('./partials/add-user-model.ejs'); %>
<script src="/js/toastify.js"></script>
<script>
    
function showDeleteToast() {
    Toastify({
        text: "User was deleted successfully!",
        duration: 3000,
        gravity: "top",
        position: "right",
        close: true,
        style: {
            background: "linear-gradient(135deg,#ef4444,#dc2626)"
        }
    }).showToast();
}

function showDeleteErrorToast() {
    Toastify({
        text: "Could not delete the user!",
        duration: 3000,
        gravity: "top",
        position: "right",
        close: true,
        style: {
            background: "linear-gradient(135deg,#ef4444,#dc2626)"
        }
    }).showToast();
}

    // delete user functionality
async function deleteUser(userId) {
    try {
        let response = await fetch(`/users/${userId}`, {
            method: "DELETE",
        });

        let result = await response.json();

        if (result.errors) {
            showDeleteErrorToast();
        } else {
            showDeleteToast();

            const row = document.getElementById(userId);
            if (row) row.remove();
        }

    } catch (error) {
        console.error(error);
        showDeleteErrorToast();
    }
}
</script>
</body>
</html>
<%- include('./partials/footer.ejs') %>